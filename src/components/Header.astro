---
import Default from "@astrojs/starlight/components/Header.astro";
---

<Default {...Astro.props}>
  <slot />
</Default>

<style is:global>
  /* Add "Try Drizby Cloud" CTA after social icons */
  .social-icons::after {
    content: "Try Drizby Cloud";
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    background: var(--sl-color-accent);
    color: #fff;
    white-space: nowrap;
    transition: background 0.15s;
    cursor: pointer;
    margin-inline-start: 0.5rem;
  }
  .social-icons {
    position: relative;
  }
  /* Wrap the pseudo-element in a clickable link via JS below */
</style>

<script>
  // Inject a real link for the CTA
  document.addEventListener('DOMContentLoaded', () => {
    const socialIcons = document.querySelector('.social-icons');
    if (!socialIcons) return;
    const cta = document.createElement('a');
    cta.href = 'https://cloud.drizby.com/register';
    cta.target = '_blank';
    cta.rel = 'noopener';
    cta.textContent = 'Try Drizby Cloud';
    cta.className = 'header-cta';
    socialIcons.appendChild(cta);
  });
</script>

<style is:global>
  .social-icons::after {
    display: none !important;
  }
  .header-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    background: var(--sl-color-accent);
    color: #fff !important;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
    margin-inline-start: 0.5rem;
  }
  .header-cta:hover {
    background: #818cf8;
    color: #fff !important;
  }
</style>
